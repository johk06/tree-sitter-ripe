{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "ripe",
  "rules": {
    "program": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "shebang"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_expr"
            }
          },
          "named": true,
          "value": "sentence"
        }
      ]
    },
    "shebang": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#!"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "_expr": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "SYMBOL",
          "name": "symbol"
        },
        {
          "type": "SYMBOL",
          "name": "block"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string"
        }
      ]
    },
    "word": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^\\s0-9\\[\\]\\;\\\\'\"`\\-()][^\\s\\[\\]\\;\\\\'\"`()]*"
          },
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "PATTERN",
            "value": "-[^\\s0-9\\[\\]\\;\\\\'\"`()][^\\s\\[\\]\\;\\\\'\"`()]*"
          }
        ]
      }
    },
    "symbol": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_expr"
              }
            },
            "named": true,
            "value": "sentence"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "PATTERN",
                "value": "[^()]"
              }
            },
            {
              "type": "SYMBOL",
              "name": "comment"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "string_escape": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "STRING",
              "value": "\\"
            },
            {
              "type": "STRING",
              "value": "n"
            },
            {
              "type": "STRING",
              "value": "e"
            },
            {
              "type": "STRING",
              "value": "r"
            },
            {
              "type": "STRING",
              "value": "t"
            }
          ]
        }
      ]
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "FIELD",
          "name": "string_content",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\]"
                },
                {
                  "type": "SYMBOL",
                  "name": "string_escape"
                }
              ]
            }
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "raw_string_content": {
      "type": "PATTERN",
      "value": "[^`]*"
    },
    "raw_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string_content"
        },
        {
          "type": "STRING",
          "value": "`"
        }
      ]
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "-"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "0x[0-9a-fA-F+/]"
              },
              {
                "type": "PATTERN",
                "value": "0o[0-9]"
              },
              {
                "type": "PATTERN",
                "value": "\\d+(\\.\\d+)?([eE][+-]?\\d+)?"
              }
            ]
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}