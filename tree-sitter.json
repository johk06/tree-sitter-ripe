{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ripe",
      "camelcase": "Ripe",
      "title": "Ripe",
      "scope": "source.ripe",
      "file-types": [
        "ripe"
      ],
      "injection-regex": "^ripe$",
      "class-name": "TreeSitterRipe"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL",
    "description": "Ripe grammar for tree-sitter",
    "authors": [
      {
        "name": "Jhk",
        "email": "jhk06@mailbox.org",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-ripe",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}